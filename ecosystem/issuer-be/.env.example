# --- runtime ---
STAGE=dev
PORT=3400
LOG_LEVEL=debug

# Postgres (status list + issued-credential records)
DATABASE_URL=postgres://issuer:issuer@localhost:5432/issuer

# Redis (auth sessions, PAR, codes, DPoP/c_nonces). Unset ⇒ in-memory single-replica dev.
REDIS_URL=redis://localhost:6379

# Credential Issuer identifier = public origin + the /eudi-issuer global prefix (no trailing slash).
ISSUER_BASE_URL=http://localhost:3400/eudi-issuer

# --- signing (from ecosystem/trusted-list: node tools/gen-signer.mjs ...) ---
# JSON strings: { "privateKeyPem": "...", "certPem": "...", "caCertPem": "..." }
# Unset ⇒ ephemeral self-signed dev keys (won't chain to the published Trusted List).
ISSUER_PID_SIGNER=
ISSUER_MDL_SIGNER=

# --- signed metadata / issuer_info (ETSI TS 119 472-3 ISS-MDATA-REG_CERT-4.2.3) ---
# The Provider's registrar_dataset for the signed-metadata issuer_info. JSON:
#   {"identifier":[{"type":"http://data.europa.eu/eudi/id/LEI","identifier":"..."}],
#    "srvDescription":[{"lang":"en","content":"..."}],"registryURI":"https://.../registry"}
# providesAttestations is auto-derived from the credential configs. Unset ⇒ sandbox default.
ISSUER_REGISTRAR_DATASET=
# Optional registrar-issued Provider registration certificate (compact JWS) → issuer_info registration_cert.
ISSUER_REGISTRATION_CERT=

# --- trust ---
# JAdES-signed Wallet Providers Trusted List used to verify Wallet Attestations (WUAs).
TRUSTED_LIST_URL=https://trusted-list.vercel.app/tl/wallet-providers.jades.json
# Pinned Scheme Operator signing cert (PEM) for the list's JAdES signature. Unset ⇒ fetch+pin scheme-operator.pem
# from the list directory. Set to the real SO cert for out-of-band pinning (recommended in prod).
ISSUER_SCHEME_OPERATOR_CERT=

# Accept wallets without a valid attestation/WUA (local dev only). Never set in prod. Secure-by-default:
# leave false (or unset) so wallet + key attestation are enforced; opt in explicitly for headless dev.
DEV_ATTESTATION_BYPASS=false

# Admin API key protecting the revoke endpoint. Unset ⇒ unprotected (dev only).
ADMIN_API_KEY=
