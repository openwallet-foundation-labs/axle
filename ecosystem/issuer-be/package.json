{
  "name": "eudi-issuer",
  "version": "0.1.0",
  "description": "EUDI credential Issuer — OpenID4VCI + HAIP (PID as SD-JWT VC & mdoc, mDL as mdoc). NestJS + Fastify.",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "migrate": "node dist/migrate",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@lukas.j.han/mdoc": "0.6.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-fastify": "^11.1.14",
    "@nestjs/terminus": "^11.0.0",
    "@peculiar/webcrypto": "^1.7.1",
    "@peculiar/x509": "^2.0.0",
    "@sd-jwt/core": "^0.17.0",
    "@sd-jwt/crypto-nodejs": "^0.17.0",
    "@sd-jwt/decode": "^0.17.0",
    "@sd-jwt/sd-jwt-vc": "^0.17.0",
    "@sd-jwt/types": "^0.17.0",
    "@sd-jwt/utils": "^0.17.0",
    "@willsoto/nestjs-prometheus": "^6.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.7.4",
    "ioredis": "^5.4.1",
    "jose": "^6.2.3",
    "nestjs-pino": "^4.6.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "postgres": "^3.4.8",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.31.10",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
