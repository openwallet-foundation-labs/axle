# EUDI Verifier (OpenID4VP relying party) — dev config
STAGE=dev
PORT=3500

# Public base URL — the base for /request, /response, /presentations and the wallet's request_uri/response_uri,
# and the audience the key-binding JWT is checked against. No trailing slash. Local dev:
VERIFIER_BASE_URL=http://localhost:3500/eudi-verifier
# verifier-fe base URL (the browser that polls the result). Optional.
VERIFIER_FE_URL=http://localhost:5176

# The WRPAC keystore (reader access cert + key) as a JSON string { privateKeyPem, certPem, caCertPem }.
# Produce it with: node tools/mint-rp.mjs  (registers an RP + mints WRPAC/WRPRC against the live registrar).
# REQUIRED (HAIP forbids a self-signed request-signing cert). Unset ⇒ boot fails unless DEV_ALLOW_EPHEMERAL_WRPAC=true.
# VERIFIER_WRPAC={"privateKeyPem":"-----BEGIN PRIVATE KEY-----\n...","certPem":"-----BEGIN CERTIFICATE-----\n...","caCertPem":"-----BEGIN CERTIFICATE-----\n..."}
# Local-dev only: allow booting without VERIFIER_WRPAC using an ephemeral self-signed cert. Never set in prod.
DEV_ALLOW_EPHEMERAL_WRPAC=false

# The WRPRC (registration cert) — a compact rc-wrp+jwt, sent by value in verifier_info.registration_cert.
# VERIFIER_WRPRC=eyJ...

# The RP registrar dataset for verifier_info.registrar_dataset (JSON). Optional (a minimal default is derived).
# VERIFIER_REGISTRAR_DATASET={"identifier":[{"type":"VAT","value":"LU..."}],"srvDescription":[{"lang":"en","content":"Hopae Demo Verifier"}]}

# Base URL of the JAdES Trusted Lists (PID + attestation issuer CAs) used to verify presentations.
TRUSTED_LIST_BASE_URL=https://trusted-list.vercel.app/tl

# LOG_LEVEL=debug
